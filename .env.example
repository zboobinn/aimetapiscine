# ─────────────────────────────────────────────────────────────────────────
# REQUISES DÈS MAINTENANT — socle applicatif, validées au boot
# (src/instrumentation.ts -> assertCoreEnv(), voir src/lib/env). Sans elles,
# `pnpm dev` / `pnpm build` échouent immédiatement.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
# Optionnelle (défaut "false") : passer à "true" UNIQUEMENT une fois
# NEXT_PUBLIC_SITE_URL sur le domaine de production final (18, decisions.md)
# — sinon robots.txt bloque toute indexation.
SEO_ALLOW_INDEXING=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────
# À VENIR — variables des specs pas encore développées. Non requises pour
# démarrer l'app aujourd'hui : chacune n'est validée (et ne doit échouer)
# qu'au moment où le code de sa spec s'exécute (lazy, voir src/lib/env).
# Laisser vide tant que la fonctionnalité correspondante n'est pas en cours.
# ─────────────────────────────────────────────────────────────────────────

# Analytics cookieless (21)
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# Stripe Checkout (10) — clé secrète seule requise pour /api/checkout
STRIPE_SECRET_KEY=
# Secret de signature webhook (10) — fourni par `stripe listen` en dev (02),
# validé séparément : ne bloque jamais la création de session Checkout
STRIPE_WEBHOOK_SECRET=

# Emails transactionnels — Resend (17). Sans domaine de production (prévu
# septembre, decisions.md) : EMAIL_FROM reste onboarding@resend.dev, et
# Resend n'autorise l'envoi qu'à l'adresse du compte tant qu'aucun domaine
# n'est vérifié — renseigner EMAIL_OVERRIDE_TO (adresse du compte Resend) en
# dev/staging pour rediriger TOUS les emails vers cette adresse (sujet
# préfixé par le destinataire réel). Laisser vide en prod une fois le domaine
# vérifié. RESEND_API_KEY absente = envoi en no-op loggé (jamais bloquant).
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_OVERRIDE_TO=

# Sécurité (23) — secrets d'authentification interne / défenses, jamais de
# config email malgré leur proximité fonctionnelle avec 17 (23b, decisions.md)
# Secret partagé avec le Database Webhook Supabase → /api/hooks/pro-activated (14/17)
PRO_ACTIVATION_HOOK_SECRET=
# Rate limiting POST /api/checkout (23) — défauts fournis par le schéma Zod si absentes
CHECKOUT_RATE_LIMIT_MAX=8
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS=60

# Blind shipping (27) — tokens fournisseur, MONO-MOT séparés par des
# virgules (jamais commités en dur dans le code, voir src/lib/blind-shipping.ts).
# Absente/vide = aucune détection (fail-open documenté, pas de crash).
BLIND_SHIPPING_DENYLIST=

# Revalidation ISR à la demande (15/19)
REVALIDATE_SECRET=

# Notifications APF / admin (11, 16, 17)
APF_LOGISTICS_EMAIL=
ADMIN_ALERT_EMAIL=

# Configuration métier calculateur/livraison (08, 12, 13) — valeurs par
# défaut fournies par le schéma Zod si absentes, donc jamais bloquant
PACK_DISCOUNT_BPS=500
LOSS_COEFF_BASE=1.15
LOSS_COEFF_STAIRS=1.20
#included ou flat
SHIPPING_MODE=included
SHIPPING_FLAT_FEE_CENTS=4000
# PROVISOIRE — surcoût transporteur Corse (2A/2B, CP 20xxx), appliqué dans les
# deux modes SHIPPING_MODE ; montant à confirmer avec APF (12, decisions.md)
SHIPPING_CORSICA_SURCHARGE_CENTS=3000

# Garantie de reprise sur erreur de cote (29 §8, A1) — off|material-only|full,
# défaut off. Décision commerciale en attente auprès d'APF ; le front
# fonctionne dans les trois cas (docs/decisions.md).
NEXT_PUBLIC_REMAKE_GUARANTEE=off

# Vérification SIRET automatique (14) — optionnelle, à obtenir sur api.insee.fr
# (API Sirene). Sans elle, l'inscription pro fonctionne quand même : le SIRET
# passe juste en statut "non vérifié automatiquement", contrôle manuel requis.
INSEE_SIRENE_API_KEY=

# Identité société — factures/mentions légales (11, 22)
COMPANY_NAME=
COMPANY_SIREN=
COMPANY_VAT=
COMPANY_ADDRESS=
