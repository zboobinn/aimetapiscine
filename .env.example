# ─────────────────────────────────────────────────────────────────────────
# REQUISES DÈS MAINTENANT — socle applicatif, validées au boot
# (src/instrumentation.ts -> assertCoreEnv(), voir src/lib/env). Sans elles,
# `pnpm dev` / `pnpm build` échouent immédiatement.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────
# À VENIR — variables des specs pas encore développées. Non requises pour
# démarrer l'app aujourd'hui : chacune n'est validée (et ne doit échouer)
# qu'au moment où le code de sa spec s'exécute (lazy, voir src/lib/env).
# Laisser vide tant que la fonctionnalité correspondante n'est pas en cours.
# ─────────────────────────────────────────────────────────────────────────

# Analytics cookieless (21)
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# Stripe Checkout (10) — clé secrète seule requise pour /api/checkout
STRIPE_SECRET_KEY=
# Secret de signature webhook (10) — fourni par `stripe listen` en dev (02),
# validé séparément : ne bloque jamais la création de session Checkout
STRIPE_WEBHOOK_SECRET=

# Resend — emails transactionnels (17)
RESEND_API_KEY=

# Revalidation ISR à la demande (15/19)
REVALIDATE_SECRET=

# Notifications APF / admin (11, 16)
APF_LOGISTICS_EMAIL=
ADMIN_ALERT_EMAIL=

# Configuration métier calculateur/livraison (08, 12, 13) — valeurs par
# défaut fournies par le schéma Zod si absentes, donc jamais bloquant
PACK_DISCOUNT_BPS=500
LOSS_COEFF_BASE=1.15
LOSS_COEFF_STAIRS=1.20
SHIPPING_MODE=included
SHIPPING_FLAT_FEE_CENTS=4000
# PROVISOIRE — surcoût transporteur Corse (2A/2B, CP 20xxx), appliqué dans les
# deux modes SHIPPING_MODE ; montant à confirmer avec APF (12, decisions.md)
SHIPPING_CORSICA_SURCHARGE_CENTS=3000

# Identité société — factures/mentions légales (11, 22)
COMPANY_NAME=
COMPANY_SIREN=
COMPANY_VAT=
COMPANY_ADDRESS=
